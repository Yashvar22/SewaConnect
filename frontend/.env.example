# ─────────────────────────────────────────────────────────────────
# SewaConnect — Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Development: http://localhost:5000/api
# Production: https://your-backend-app.onrender.com/api
VITE_API_URL=https://your-backend-app.onrender.com/api

# Razorpay public key ID (safe to expose in frontend build)
# Only the KEY_ID (not the secret) should be specified here
VITE_RAZORPAY_KEY_ID=rzp_test_your_public_key_id
