# ─────────────────────────────────────────────────────────────────
# SewaConnect — Backend Environment Variables Template
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ngo_connect?retryWrites=true&w=majority

# Port for the Express server to listen on
PORT=5000

# JSON Web Token (JWT) secret key
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary Credentials (for image hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service Config (Nodemailer Gmail SMTP)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Client (Frontend) URL for CORS and email links
CLIENT_URL=http://localhost:5173

# Razorpay API Credentials (for payment gateway)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
